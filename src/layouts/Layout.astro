---
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import { CONTACT } from '../data/constants';

interface Props {
  title?: string;
}

const { title = 'Ravi Both | Full-Stack Engineer & Tech Consultant' } = Astro.props;
const description = 'Your tech partner for growing businesses. Full-stack engineering, consulting, and modern web development by Ravi Both.';
const siteUrl = 'https://www.raviboth.com';
const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f6" />
    <link rel="canonical" href={siteUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ravi Both — Full-Stack Engineer & Tech Consultant" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "name": "Ravi Both",
            "jobTitle": "Full-Stack Engineer & Tech Consultant",
            "url": "https://www.raviboth.com",
            "email": CONTACT.email,
            "sameAs": [
              CONTACT.github,
              CONTACT.linkedin
            ]
          },
          {
            "@type": "WebSite",
            "name": "Ravi Both",
            "url": "https://www.raviboth.com",
            "description": "Your tech partner for growing businesses. Full-stack engineering, consulting, and modern web development by Ravi Both."
          }
        ]
      })}
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav client:load />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; 2026 Ravi Both - Spring edition</p>
    </footer>

    <!-- Scroll-reveal observer for non-hydrated [data-reveal] elements -->
    <script>
      (function () {
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) return; // CSS handles immediate display

        const revealElements = document.querySelectorAll('[data-reveal]');
        if (!revealElements.length) return;

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
        );

        revealElements.forEach((el) => observer.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  .site-footer {
    background-color: var(--color-footer-bg);
    padding: 24px var(--space-section-x);
    text-align: center;
  }

  .site-footer p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-footer-text);
  }

  /* Skip-to-content link */
  .skip-link {
    position: fixed;
    top: -100%;
    left: 16px;
    z-index: 9999;
    padding: 8px 20px;
    background-color: var(--color-primary-dark);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: top var(--transition-fast);
  }

  .skip-link:focus {
    top: 16px;
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }
</style>
